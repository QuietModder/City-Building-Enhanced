<tactics>

    <!-- ========================================================= -->
    <!-- Autonomous Bunker Mills defensive attack                 -->
    <!-- Works even with no units garrisoned                       -->
    <!-- Villagers inside add a small capped damage bonus          -->
    <!-- ========================================================= -->
    <action>
        <name stringid="38133">BunkerMillsRangedAttack</name>
        <type>Attack</type>

        <attackaction>1</attackaction>
        <rangedlogic>1</rangedlogic>

        <!-- +5% damage per garrisoned villager, capped at +25% -->
        <scalebycontainedunittype>
            <rate type="AbstractVillager">0.05</rate>
        </scalebycontainedunittype>
        <damagefactorcap>4</damagefactorcap>


        <maxheight>0</maxheight>

        <accuracy>1.0</accuracy>
        <aimbonus>0</aimbonus>
        <maxspread>5</maxspread>
        <spreadfactor>0.25</spreadfactor>
        <trackrating>120</trackrating>

        <unintentionaldamagemultiplier>0.7</unintentionaldamagemultiplier>

        <projectile>Cannonball</projectile>
        <impacteffect>effects\impacts\gun</impacteffect>

        <rate type="Unit">1.0</rate>

        <instantballistics>1</instantballistics>
        <perfectaccuracy>1</perfectaccuracy>
    </action>

    <action>
        <name stringid="38133">BunkerMillsMannedAttack</name>
        <type>Attack</type>

        <attackaction>1</attackaction>
        <rangedlogic>1</rangedlogic>

        <activeifcontainsunits>1</activeifcontainsunits>

        <anim>RangedAttack</anim>
        <maxheight>0</maxheight>

        <accuracy>1.0</accuracy>
        <aimbonus>0</aimbonus>
        <maxspread>5</maxspread>
        <spreadfactor>0.25</spreadfactor>
        <trackrating>120</trackrating>

        <unintentionaldamagemultiplier>0.7</unintentionaldamagemultiplier>

        <projectile>Cannonball</projectile>
        <impacteffect>effects\impacts\cannon</impacteffect>

        <rate type="Unit">1.0</rate>

        <instantballistics>1</instantballistics>
        <perfectaccuracy>1</perfectaccuracy>
    </action>

    <!-- ========================================================= -->
    <!-- Existing Bunker Mills food production                     -->
    <!-- ========================================================= -->
    <action>
        <name stringid="43019">AutoGather</name>
        <type>AutoGather</type>
        <active>1</active>
        <persistent>1</persistent>
    </action>

    <!-- ========================================================= -->
    <!-- Default Bunker Mills behavior                             -->
    <!-- ========================================================= -->
    <tactic>Normal<attacktype>LogicalTypeRangedUnitsAttack</attacktype>
        <autoattacktype>LogicalTypeRangedUnitsAutoAttack</autoattacktype>
        <attackresponsetype>LogicalTypeRangedUnitsAttack</attackresponsetype>

        <action priority="50">BunkerMillsRangedAttack</action>
        <action priority="75">BunkerMillsMannedAttack</action>

        <action>AutoGather</action>
    </tactic>

</tactics>